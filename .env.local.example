NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
# ANTHROPIC_API_KEY is needed in Phase 1 for the Platform Agent; add it when you get there
# CRON_SECRET protects /api/cron/* — Vercel Cron sends it as `Authorization: Bearer <secret>`.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-me-with-a-random-32-byte-hex-string

# MCP_CONNECTION_ENCRYPTION_KEY — symmetric key used by pgcrypto to
# encrypt bearer tokens stored in the `mcp_connections` table. Must be
# a 32-byte hex string (64 hex chars). Missing or malformed keys will
# cause encryption operations to fail loudly at first use. Key rotation
# (re-encrypting existing rows after changing the key) is a Phase 2
# concern — for MVP the key is static.
# Generate with: openssl rand -hex 32
MCP_CONNECTION_ENCRYPTION_KEY=replace-me-with-a-random-32-byte-hex-string

# 32-byte hex secret (openssl rand -hex 32) used to MAC OAuth state params for connector installs.
CONNECTORS_STATE_SECRET=

# Firecrawl (Task 1 — webfetch)
FIRECRAWL_API_KEY=                    # required. Get from https://firecrawl.dev/app/api-keys
FIRECRAWL_ENABLED=true                # ops kill-switch. Set 'false' to disable web_search + web_fetch.
FIRECRAWL_RETRY_MAX_ATTEMPTS=3        # built-in SDK retry budget for 429/5xx (exponential backoff from 1s)

# MCP_OAUTH_JWT_SECRET — HS256 signing key for MCP OAuth access tokens
# (src/lib/oauth/jwt.ts). Must be at least 32 bytes. Rotating this
# invalidates all outstanding access tokens, which is the intended
# emergency-revoke behaviour.
# Generate with: openssl rand -hex 32
MCP_OAUTH_JWT_SECRET=""

# NEXT_PUBLIC_APP_ORIGIN — public origin used to build absolute URLs in
# server-emitted headers and discovery documents. Specifically used in
# the WWW-Authenticate `resource_metadata` pointer on /api/mcp 401s, so
# MCP clients can locate the OAuth resource-metadata JSON. Falls back to
# https://locus.app when unset.
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# === Resend — marketing waitlist ===
# Create at https://resend.com/api-keys (read-only to the audiences scope is enough).
RESEND_API_KEY=

# Create an audience at https://resend.com/audiences and paste its UUID here.
RESEND_WAITLIST_AUDIENCE_ID=

# GitHub API access for skill import. public_repo scope is sufficient.
GITHUB_TOKEN=

# Subagent harness
TATARA_SUBAGENTS_ENABLED=false
TATARA_MAX_SUBAGENTS_PER_TURN=10
# TATARA_MODEL_OVERRIDE_<AGENT_SLUG>=<ApprovedModelId>
# Example:
# TATARA_MODEL_OVERRIDE_BRAIN_EXPLORE=google/gemini-2.5-flash-lite
