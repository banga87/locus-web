NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
# ANTHROPIC_API_KEY is needed in Phase 1 for the Platform Agent; add it when you get there
# CRON_SECRET protects /api/cron/* — Vercel Cron sends it as `Authorization: Bearer <secret>`.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-me-with-a-random-32-byte-hex-string

# MCP_CONNECTION_ENCRYPTION_KEY — symmetric key used by pgcrypto to
# encrypt bearer tokens stored in the `mcp_connections` table. Must be
# a 32-byte hex string (64 hex chars). Missing or malformed keys will
# cause encryption operations to fail loudly at first use. Key rotation
# (re-encrypting existing rows after changing the key) is a Phase 2
# concern — for MVP the key is static.
# Generate with: openssl rand -hex 32
MCP_CONNECTION_ENCRYPTION_KEY=replace-me-with-a-random-32-byte-hex-string

# Firecrawl (Task 1 — webfetch)
FIRECRAWL_API_KEY=                    # required. Get from https://firecrawl.dev/app/api-keys
FIRECRAWL_ENABLED=true                # ops kill-switch. Set 'false' to disable web_search + web_fetch.
FIRECRAWL_RETRY_MAX_ATTEMPTS=3        # built-in SDK retry budget for 429/5xx (exponential backoff from 1s)
